  <diagram name="Page-1" id="oX_fe3E9T0NxiihMDpuI">
    <mxGraphModel dx="4589" dy="6751" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="o94Lm6SKpwxqL8Yj-1tM-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h1&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Ticket&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Ticket Booking System :&amp;nbsp;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/h1&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;A platform that allows users to discover and purchase tickets for various entertainment options like movies, concerts, and live events&lt;/span&gt;&amp;nbsp;&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="450" x="-1430" y="-5380" as="geometry" />
        </mxCell>
        <mxCell id="o94Lm6SKpwxqL8Yj-1tM-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h1&gt;&lt;font style=&quot;font-size: 19px;&quot;&gt;Functional Requirements&lt;/font&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;The user must be able to discover events using filters such as the Event Title, the City/Location, and the specific Date of the show.&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;user should be able to view the details of the events (seats, description, metadata)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;user should be able to do a booking for that event&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="770" x="-1440" y="-5260" as="geometry" />
        </mxCell>
        <mxCell id="o94Lm6SKpwxqL8Yj-1tM-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;Non Functional Requirements&lt;/h2&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Scale - 100M DAU&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;CAP Theorem : Highly available with respect to searching and viewing an event .&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;Highly consistent with respect to&amp;nbsp; booking a particular Ticket&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="700" x="-1440" y="-5060" as="geometry" />
        </mxCell>
        <mxCell id="o94Lm6SKpwxqL8Yj-1tM-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Core Entity&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;1.User&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;2.Event&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;3.Venue&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;4.Ticket&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="20" width="170" x="-1440" y="-4830" as="geometry" />
        </mxCell>
        <mxCell id="o94Lm6SKpwxqL8Yj-1tM-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;&lt;font face=&quot;Helvetica&quot;&gt;API Designing :&lt;/font&gt;&lt;/h2&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: medium; background-color: rgb(255, 255, 255); color: rgb(13, 31, 45);&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;1.&amp;nbsp;&lt;span style=&quot;background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18)); color: rgb(13, 31, 45);&quot;&gt;GET&amp;nbsp; : /v1/search?q={searchTerm}&amp;amp;location={location}&amp;amp;date={date}&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(55, 65, 81), rgb(174, 183, 197)); background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; color: light-dark(rgb(55, 65, 81), rgb(174, 183, 197)); background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18));&quot;&gt;—&amp;gt;&amp;nbsp; List&amp;lt;EventId&amp;gt;&amp;nbsp; (pagination)&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: medium; background-color: rgb(255, 255, 255); color: rgb(13, 31, 45);&quot;&gt;&lt;span style=&quot;font-weight: normal; color: light-dark(rgb(55, 65, 81), rgb(174, 183, 197)); background-color: light-dark(rgb(255, 255, 255), rgb(18, 18, 18));&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); font-size: medium; color: rgb(13, 31, 45);&quot;&gt;2. GET&amp;nbsp; : /v1/event/{eventId}&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255); color: rgb(55, 65, 81); font-size: medium;&quot;&gt;—&amp;gt;&amp;nbsp; Event Details &amp;amp; Location &amp;amp; Seats[]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;color: rgb(55, 65, 81); background-color: rgb(255, 255, 255); font-size: medium;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;color: rgb(55, 65, 81); background-color: rgb(255, 255, 255); font-size: medium;&quot;&gt;3.POST : /v1/booking/reserve&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;color: rgb(55, 65, 81); background-color: rgb(255, 255, 255); font-size: medium;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;{&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;color: rgb(55, 65, 81); background-color: rgb(255, 255, 255); font-size: medium;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;List&amp;lt;Seat&amp;gt; seats ;&amp;nbsp; &amp;nbsp;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Helvetica&quot;&gt;&lt;span style=&quot;color: rgb(55, 65, 81); background-color: rgb(255, 255, 255); font-size: medium;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;}&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font face=&quot;Helvetica&quot;&gt;&amp;nbsp;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Here we will send the userId in Header of request for secure API Call&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;We will receive a bookingId that will be used for payment&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;4.POST: /v1/booking/confirm&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;{&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;bookingId , paymentDetails&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(55, 65, 81); font-size: medium; background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;}&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" vertex="1">
